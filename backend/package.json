{
  "name": "az900-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "seed": "ts-node src/seed/seed.ts",
    "seed:concepts": "ts-node src/seed/seedConcepts.ts",
    "seed:chapters": "ts-node src/seed/seedChapterQuizzes.ts",
    "seed:questions": "ts-node src/seed/seedPracticeQuestions.ts",
    "seed:exam": "ts-node src/seed/seedExamQuestions.ts",
    "seed:flashcards": "ts-node src/seed/seedFlashcards.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "prisma": "^5.19.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
